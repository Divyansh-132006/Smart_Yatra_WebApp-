# ========== CRITICAL - MUST BE SET ==========
# Generate a strong random secret key (at least 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here_minimum_32_chars

# ========== DATABASE ==========
MONGO_URI=mongodb://localhost:27017/smart-yatra
# For production, use MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-yatra

# ========== JWT TOKEN EXPIRY ==========
# Access token expiry (15 minutes recommended for security)
JWT_EXPIRES_IN=15m

# Refresh token expiry (30 days)
JWT_REFRESH_EXPIRES_IN=30d

# ========== EMAIL SERVICE (Brevo) ==========
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_SENDER_ADDRESS=noreply@smartyatra.com

# ========== SMS SERVICE (TextBee) - Optional ==========
TEXTBEE_API_KEY=your_textbee_api_key_here
TEXTBEE_DEVICE_ID=your_textbee_device_id_here

# ========== SERVER ==========
PORT=3000
NODE_ENV=development

# 🔒 HTTPS/SSL Configuration (Development)
# HTTPS_ENABLED: Set to 'true' to enable HTTPS with self-signed certificates
# Generate certificates first: node generate-certs.js
# When enabled, server runs on port 3001 (HTTPS) instead of 3000 (HTTP)
HTTPS_ENABLED=true

# ========== FRONTEND ==========
# This is used by frontend to know where backend is
# Switch from HTTP to HTTPS port when HTTPS_ENABLED=true
REACT_APP_API_URL=https://192.168.1.175:3001
REACT_APP_USE_HTTPS=true
